# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Session secret (generate a random string, e.g. openssl rand -hex 32)
SESSION_SECRET=your-random-secret-here

# TMDB API key (get one at https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your-tmdb-api-key

# Google OAuth (optional — only needed if you want Google login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Set this to your deployed app's URL when running in production
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Port (defaults to 5000 if not set)
PORT=5000
